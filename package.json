{
  "name": "arc-cli",
  "version": "0.1.0",
  "description": "CLI tool for Arc Network - Circle's EVM-compatible L1 blockchain with USDC as native gas",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arc": "./dist/bin/arc-cli.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/src/contracts && cp src/contracts/* dist/src/contracts/ 2>/dev/null || true",
    "dev": "tsx bin/arc-cli.ts",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"bin/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"bin/**/*.ts\""
  },
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "blockchain",
    "cli",
    "evm",
    "x402"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@circle-fin/adapter-circle-wallets": "^1.2.0",
    "@circle-fin/bridge-kit": "^1.6.0",
    "@circle-fin/developer-controlled-wallets": "^10.1.0",
    "@circle-fin/smart-contract-platform": "^10.1.0",
    "@x402/core": "^2.4.0",
    "@x402/evm": "^2.4.0",
    "@x402/express": "^2.4.0",
    "@x402/fetch": "^2.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "inquirer": "^12.0.0",
    "open": "^10.0.0",
    "ora": "^8.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
