# Circle API credentials
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_ENTITY_SECRET=your_entity_secret

# Arc Network RPC (optional - defaults to public testnet RPC)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Private key for local wallet operations (optional)
PRIVATE_KEY=your_private_key_hex

# Pinata IPFS (optional - for NFT image uploads)
# Get your JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_token

# x402 configuration (optional)
X402_PORT=3000
X402_PRICE=0.01
